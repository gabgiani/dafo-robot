<mujoco model="g1_warehouse_scene_full">
  <include file="g1_29dof_with_hand.xml"/>

  <asset>
    <texture type="cube" name="box_a_tex" builtin="checker" mark="edge" rgb1="0.83 0.29 0.21" rgb2="0.62 0.18 0.12"
      markrgb="0.95 0.7 0.6" width="128" height="128"/>
    <material name="box_a" texture="box_a_tex" texuniform="true" specular="0.35" shininess="0.4" reflectance="0.05"/>
    <texture type="cube" name="box_b_tex" builtin="checker" mark="edge" rgb1="0.21 0.45 0.83" rgb2="0.12 0.28 0.62"
      markrgb="0.6 0.75 0.95" width="128" height="128"/>
    <material name="box_b" texture="box_b_tex" texuniform="true" specular="0.35" shininess="0.4" reflectance="0.05"/>
    <material name="shelf_frame" rgba="0.22 0.22 0.24 1" specular="0.4" shininess="0.3"/>
    <material name="shelf_plank" rgba="0.55 0.41 0.29 1" specular="0.15" shininess="0.1"/>
  </asset>

  <worldbody>
    <!-- Camara fija (se reposiciona en tiempo real a la cabeza del robot desde Python). -->
    <camera name="scene_cam" pos="0.3 0 1.3" xyaxes="0 -1 0 0.35 0 0.94" fovy="60"/>

    <!-- Dos cajas sueltas en el piso, delante del punto de partida del robot (+x). -->
    <body name="box_a" pos="2.2 0.35 0.10">
      <freejoint/>
      <geom name="box_a_geom" type="box" size="0.10 0.10 0.10" material="box_a" mass="0.5"/>
    </body>

    <body name="box_b" pos="2.8 -0.35 0.10">
      <freejoint/>
      <geom name="box_b_geom" type="box" size="0.10 0.10 0.10" material="box_b" mass="0.5"/>
    </body>

    <!-- Estante fijo mas adelante, con dos niveles, para caminar hacia el. -->
    <body name="shelf" pos="4.5 0 0">
      <geom type="box" pos="-0.25 0.35 0.45" size="0.02 0.02 0.45" material="shelf_frame"/>
      <geom type="box" pos="0.25 0.35 0.45" size="0.02 0.02 0.45" material="shelf_frame"/>
      <geom type="box" pos="-0.25 -0.35 0.45" size="0.02 0.02 0.45" material="shelf_frame"/>
      <geom type="box" pos="0.25 -0.35 0.45" size="0.02 0.02 0.45" material="shelf_frame"/>
      <geom name="shelf_plank_low" type="box" pos="0 0 0.45" size="0.28 0.38 0.015" material="shelf_plank"/>
      <geom name="shelf_plank_high" type="box" pos="0 0 0.85" size="0.28 0.38 0.015" material="shelf_plank"/>
    </body>
  </worldbody>
</mujoco>
